---
import homepageData from '../../content/homepage/Homepage.json';

const contact = homepageData.contact;
---

<section id="contact" class="contact__container">
  <div class="contact wrapper">
    <div class="contact__data" style={`background-image: url(${contact?.backgroundImage})`}>
      <h2 class="contact__title">{contact?.title}</h2>
      <p class="contact__text">{contact?.text}</p>
      <ul class="contact__list">
        {contact?.contactItems?.map((item: any) => (
          <li class="contact__items">
            <Fragment set:html={item.icon} />
            <a aria-label={item.ariaLabel} href={item.href}>{item.label}</a>
          </li>
        ))}
      </ul>
    </div>
    <form class="contact__form" action="">
      <fieldset class="contact__form__texts">
        <legend style="display: none">Informații Personale</legend>

        <div class="contact__form__input">
          <label for="first-name">Prenume</label>
          <input type="text" id="first-name" placeholder="Prenume" required />
        </div>

        <div class="contact__form__input">
          <label for="last-name">Nume</label>
          <input type="text" id="last-name" placeholder="Nume" />
        </div>

        <div class="contact__form__input">
          <label for="email">Email</label>
          <input type="email" id="email" placeholder="exemplu@email.com" required />
        </div>

        <div class="contact__form__input">
          <label for="phone-number">Număr de telefon</label>
          <div class="contact__form__input__phone">
            <select aria-label="Cod țară" name="phone-number-locale" id="phone-number-locale">
              <option value="1">+1</option>
              <option value="44">+44</option>
              <option value="373">+373</option>
            </select>
            <input type="tel" id="phone-number" placeholder="555-0123" required />
          </div>
        </div>
      </fieldset>

      <fieldset class="contact__form__specialty">
        <legend style="display: none">Metoda preferată de contact</legend>
        <input type="radio" id="contactChoice1" name="contact" value="email" checked />
        <label for="contactChoice1">Email</label>

        <input type="radio" id="contactChoice2" name="contact" value="phone" />
        <label for="contactChoice2">Telefon</label>

        <input type="radio" id="contactChoice3" name="contact" value="text" />
        <label for="contactChoice3">Mesaj text</label>

        <input type="radio" id="contactChoice5" name="contact" value="other" />
        <label for="contactChoice5">Altceva</label>
      </fieldset>

      <fieldset class="contact__form__input">
        <label for="message">Mesaj</label>
        <textarea
          id="message"
          class="contact__form__input__message"
          placeholder="Spune-ne cum te putem ajuta..."
        ></textarea>
      </fieldset>

      <fieldset class="contact__form__policy">
        <legend style="display: none">Sunt de acord cu politica de confidențialitate</legend>
        <label for="privacy1" class="contact__policy__label">
          <input id="privacy1" type="checkbox" required />
          Sunt de acord cu Termenii și Condițiile
        </label>
        <label for="privacy2" class="contact__policy__label">
          <input id="privacy2" type="checkbox" />
          Abonează-te la newsletter-ul nostru
        </label>
      </fieldset>

      <button type="submit" class="button is-primary btn-primary">Trimite Mesaj</button>
    </form>
  </div>
</section>

<style>
.contact__container {
  background-color: var(--secondary);
  padding: 5rem 0 7.5rem 0;
}

.contact {
  display: flex;
  border-radius: 12px;
  height: 40rem;
  width: 100%;
  background-color: var(--white);
}

.contact__data {
  border-radius: 12px;
  padding: 2.625rem;
  width: 30%;
  background-size: cover;
  background-repeat: no-repeat;
  background-position: left;
}

.contact__title {
  font-size: 3rem;
  margin-bottom: 1rem;
  font-family: OutfitSemibold;
}

.contact__text {
  font-size: 0.875rem;
  margin-bottom: 3.5rem;
}

.contact__list {
  display: flex;
  flex-direction: column;
  gap: 19px;
}

.contact__items {
  display: flex;
  gap: 1.5rem;
  align-items: center;

  a {
    color: var(--black);
  }
}

.contact__form {
  width: 80%;
  padding: 3rem 1.25rem;
  display: flex;
  flex-direction: column;
  gap: 1.625rem;

  button {
    align-self: self-end;
  }
}

.contact__form__texts {
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: 1fr 1fr;
  gap: 1rem;
}

.contact__form__input {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.contact__form__input label {
  font-size: 0.875rem;
}

.contact__form__input input[type="text"],
.contact__form__input input[type="email"],
.contact__form__input textarea {
  border: 1px solid var(--black);
  outline: 1px solid transparent;
  border-radius: 3px;
  background-color: var(--white);
  padding: 0.75rem 0.5rem;

  &:focus {
    border: 1px solid var(--primary);
    outline: 1px solid var(--primary);
  }
}

.contact__form__input__phone {
  border: 1px solid var(--black);
  outline: 1px solid transparent;
  border-radius: 3px;
  background-color: var(--white);
  padding: 0.75rem 0.5rem;
  display: flex;
  gap: 0.5rem;

  &:focus {
    border: 1px solid var(--primary);
    outline: 1px solid var(--primary);
  }

  & select {
    font-family: OutfitRegular;
  }
}

.contact__form__input:has(input[required]) label:before {
  content: "*";
  color: red;
}

.contact__form__specialty {
  display: flex;
  justify-content: space-between;

  & input {
    position: absolute;
    opacity: 0;
    pointer-events: none;

    &:checked + label:before {
      border: 2px solid var(--primary);
      background-color: var(--primary);
      box-shadow: inset 0 0 0 2px var(--white);
    }

    &:focus-visible + label {
      outline: 3px solid #93c5fd;
      outline-offset: 2px;
    }
  }

  & label {
    cursor: pointer;
  }

  & label:before {
    content: "";
    background: var(--white);
    border-radius: 100%;
    border: 2px solid var(--black);
    display: inline-block;
    width: 1.2em;
    height: 1.2em;
    position: relative;
    top: -0.1em;
    margin-right: 0.5rem;
    vertical-align: top;
    cursor: pointer;
    text-align: center;
    transition: all 250ms ease;
    user-select: none;
  }
}

.contact__form__input__message {
  height: 6.5rem;
  resize: none;
}

.contact__form__policy {
  display: flex;
  gap: 1rem;
}

.contact__policy__label {
  cursor: pointer;
  position: relative;
  display: flex;
  align-items: center;
  gap: 0.5rem;

  &::before {
    content: "";
    width: 18px;
    height: 18px;
    display: inline-block;
    background-color: var(--white);
    border: 2px solid grey;
    border-radius: 2px;
  }

  &:has(input:checked)::before {
    background-color: var(--primary);
    border: 2px solid var(--primary);
  }

  &:has(input:focus-visible) {
    outline: 3px solid #93c5fd;
    outline-offset: 2px;
  }

  input {
    opacity: 0;
    position: absolute;
    pointer-events: none;
  }
}

@media (max-width: 1024px) {
  .contact {
    height: auto;
  }

  .contact__data {
    width: 40%;
  }
}

@media (max-width: 768px) {
  .contact {
    flex-direction: column;
    height: auto;
  }

  .contact__data {
    width: 100%;
    padding: 2rem;
  }

  .contact__form {
    width: 100%;
    padding: 2rem 1rem;
  }

  .contact__form__texts {
    grid-template-columns: 1fr;
  }

  .contact__form__specialty {
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .contact__form__policy {
    flex-direction: column;
  }

  .contact__form button {
    align-self: stretch;
  }
}
</style>
