---
import client from "../../tina/__generated__/client"

const response = await client.queries.mascotConnection();
const mascot = response.data.mascotConnection.edges?.[0]?.node;
---

<div class="mascot" id="mascot">
  <div class="mascot__bubble">
    <p class="mascot__message">
      {mascot?.message}
    </p>
  </div>
  <img src={mascot?.mascotImage} alt={mascot?.mascotName} class="mascot__img" />
</div>

<style>
.mascot {
  position: fixed;
  bottom: 24px;
  right: 24px;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;

  opacity: 0;
  animation:
    mascotAppear 0.6s ease-out 2s forwards,
    mascotBounce 3s ease-in-out 2.6s infinite;
}

.mascot__img {
  width: 100px;
  height: auto;
  cursor: pointer;
  filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.15));
  transition: transform 0.3s ease;
}

.mascot:hover .mascot__img {
  animation: mascotWiggle 0.5s ease-in-out;
}

.mascot__bubble {
  background: var(--primary);
  color: #fff;
  padding: 10px 16px;
  border-radius: 12px;
  max-width: 200px;
  text-align: center;
  font-size: 0.8rem;
  line-height: 1.4;
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
  position: relative;

  opacity: 0;
  visibility: hidden;
  transform: translateY(8px) scale(0.95);
  transition:
    opacity 0.3s ease,
    visibility 0.3s ease,
    transform 0.3s ease;
}

.mascot__bubble::after {
  content: "";
  position: absolute;
  bottom: -8px;
  left: 50%;
  translate: -50% 0;
  border-width: 8px 8px 0;
  border-style: solid;
  border-color: var(--primary) transparent transparent;
}

.mascot:hover .mascot__bubble {
  opacity: 1;
  visibility: visible;
  transform: translateY(0) scale(1);
}

@keyframes mascotAppear {
  from {
    opacity: 0;
    transform: translateY(60px) scale(0.8);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes mascotBounce {
  0%, 100% { transform: translateY(0); }
  25% { transform: translateY(-8px) rotate(2deg); }
  50% { transform: translateY(0); }
  75% { transform: translateY(-5px) rotate(-2deg); }
}

@keyframes mascotWiggle {
  0%   { transform: rotate(0deg); }
  20%  { transform: rotate(12deg); }
  40%  { transform: rotate(-10deg); }
  60%  { transform: rotate(6deg); }
  80%  { transform: rotate(-4deg); }
  100% { transform: rotate(0deg); }
}

@media (max-width: 768px) {
  .mascot {
    bottom: calc(2rem + 3rem + 12px);
    right: 5px;
  }

  .mascot__img {
    width: 72px;
  }

  .mascot__bubble {
    max-width: 160px;
    font-size: 0.75rem;
    padding: 8px 12px;
  }
}
</style>
